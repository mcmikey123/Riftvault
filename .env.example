# Server configuration (all optional — sane defaults in apps/server/src/env.ts)
PORT=8787
# DATA_DIR=/srv/riftvault/data          # sqlite + img-cache live here (excluded from deploys)
# VAULT_KEY=                            # shared secret for the x-vault-key header; empty = open (use Caddy basic auth)
# ANTHROPIC_API_KEY=                    # required for photo scanning (/api/scan)
# SCAN_MODEL=claude-haiku-4-5
# SCAN_MODEL_FALLBACK=claude-sonnet-4-6
# CARD_SOURCE=riftscribe                # riftscribe | riot
# RIFTSCRIBE_BASE=https://riftscribe.gg
